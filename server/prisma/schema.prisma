generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

enum UserRole {
  ADMIN
  MEMBER
}

model Organization {
  id         String           @id @default(cuid())
  name       String
  inviteCode String           @unique
  createdAt  DateTime         @default(now())
  updatedAt  DateTime         @updatedAt

  // Relations
  memberships OrganizationMembership[]
  mealSignups MealSignup[]

  @@map("organizations")
}

model OrganizationMembership {
  id             String       @id @default(cuid())
  clerkId        String
  organizationId String
  role           UserRole     @default(MEMBER)
  joinedAt       DateTime     @default(now())
  isLastSelected Boolean      @default(false)

  // Relations
  organization Organization @relation(fields: [organizationId], references: [id], onDelete: Cascade)

  @@unique([clerkId, organizationId])
  @@map("organization_memberships")
}

// 食事注文種別マスタ
// NONE: 未申込
// NORMAL: 通常申込（自宅で食べる）
// TAKEOUT: 持ち出し申込（弁当など）
model MealOrderType {
  id String @id

  // Relations
  breakfastSignups MealSignup[] @relation("BreakfastOrderType")
  lunchSignups     MealSignup[] @relation("LunchOrderType")
  dinnerSignups    MealSignup[] @relation("DinnerOrderType")

  @@map("meal_order_types")
}

model MealSignup {
  id                    String   @id @default(cuid())
  date                  DateTime
  breakfastOrderTypeId  String
  lunchOrderTypeId      String
  dinnerOrderTypeId     String
  createdAt             DateTime @default(now())
  updatedAt             DateTime @updatedAt
  clerkId               String
  organizationId        String

  // Relations
  organization         Organization  @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  breakfastOrderType   MealOrderType @relation("BreakfastOrderType", fields: [breakfastOrderTypeId], references: [id])
  lunchOrderType       MealOrderType @relation("LunchOrderType", fields: [lunchOrderTypeId], references: [id])
  dinnerOrderType      MealOrderType @relation("DinnerOrderType", fields: [dinnerOrderTypeId], references: [id])

  @@unique([clerkId, organizationId, date])
  @@map("meal_signups")
}

model UserProfile {
  clerkId     String   @id
  displayName String
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  @@map("user_profiles")
}
